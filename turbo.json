{
"$schema": "./.vscode/schemas/turbo.schema.json",
  "ui": "tui",
  "globalEnv": [
  "DOCS_VALIDATION_URL",
  "NEXT_PUBLIC_PITCH_DECK_PDF_URL",
  "DEVELOPMENT_LOG_SECRET",
  "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_SECURE",
    "SMTP_USER",
    "SMTP_PASS"
],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
