{
"$schema": "./.vscode/schemas/turbo.schema.json",
  "ui": "tui",
  "globalEnv": [
  "DOCS_VALIDATION_URL",
  "NEXT_PUBLIC_PITCH_DECK_PDF_URL",
  "DEVELOPMENT_LOG_SECRET",
  "SMTP_HOST",
  "NODE_ENV",
    "SMTP_PORT",
    "SMTP_SECURE",
    "SMTP_USER",
    "SMTP_PASS",
    "AUTH_ABUSE_HASH_SECRET",
    "ANDROID_APP_PACKAGE_NAME",
    "ANDROID_APP_SHA256_CERT_FINGERPRINT",
    "NEXT_PUBLIC_AUTH_COOKIE_DOMAIN",
    "NEXT_PUBLIC_COMMUNITYHUB_WALLET_SCHEME",
    "NEXT_PUBLIC_MAIN_APP_URL",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "TURNSTILE_SECRET_KEY"
],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
