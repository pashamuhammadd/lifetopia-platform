{
  "name": "lifetopia-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "docs:generate": "node scripts/generate-docs.mjs",
    "project:status": "node scripts/project-status.mjs",
    "project:update": "node scripts/project-update.mjs",
    "sync:public": "node scripts/sync-public.mjs",
    "project:doctor": "node scripts/project-doctor.mjs"
  },
  "devDependencies": {
    "pg": "^8.22.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=18"
  }
}